<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Reastaurant</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Reastaurant.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        @* <div> *@
        @* <img src="/images/download1.jpg" class="img-fluid w-100" style="height: 550px; object-fit: cover;" alt="Header Image" /> *@
        @* </div> *@
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" href="#">
                    <i class="bi bi-shop text-warning me-2 fs-3"></i>
                    <span class="fw-bold">RestaurantPro</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Menu" asp-action="Menu">Menu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Category" asp-action="Category">Category</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#orders">Order Detail</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="About" asp-action="Before_Login_About">About</a>
                        </li>
                    </ul>

                    <div class="d-flex gap-2">
                        <a class="nav-link" asp-controller="" asp-action="">Cart</a>
                        <a asp-area="" asp-controller="Account" asp-action="Login">
                            <button class="btn btn-outline-primary">👤 Log In</button>
                        </a>
                        <a asp-area="" asp-controller="Account" asp-action="Register">
                        <button class="btn btn-warning">👤 Sign Up</button>
                        </a>
                    </div>
                </div>
            </div>
        </nav><!-- Hero Carousel -->
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Reastaurant - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> *@

    <!-- Footer -->
    <footer class="bg-secondary text-dark py-5 mt-auto">
        <div class="container">
            <div class="row">
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-shop text-warning me-2 fs-4"></i>
                        <h5 class="mb-0">RestaurantPro</h5>
                    </div>
                    <p class="text-muted">Professional restaurant management system for modern businesses.</p>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Menu" asp-action="Menu" class="text-muted text-decoration-none">Menu</a></li>
                        <li class="mb-2"><a href="#orders" class="text-muted text-decoration-none">Orders</a></li>
                        <li class="mb-2"><a href="#about" class="text-muted text-decoration-none">About</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">Support</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#contact" class="text-muted text-decoration-none">Contact Us</a></li>
                        <li class="mb-2"><a href="#privacy" class="text-muted text-decoration-none">Privacy Policy</a></li>
                        <li class="mb-2"><a href="#accessibility" class="text-muted text-decoration-none">Accessibility</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">Contact Info</h6>
                    <div class="text-muted">
                        <p class="mb-2"><i class="bi bi-envelope me-2"></i>info@restaurantpro.com</p>
                        <p class="mb-2"><i class="bi bi-telephone me-2"></i>(555) 123-4567</p>
                        <p class="mb-2"><i class="bi bi-geo-alt me-2"></i>123 Restaurant St, Food City</p>
                    </div>
                </div>
            </div>

            <hr class="my-4">
            <div class="text-center text-muted">
                <p class="mb-0">&copy; 2024 RestaurantPro. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
