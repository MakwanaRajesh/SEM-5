@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">
    <!-- Title -->
    <div class="text-center mb-5">
        <h1 class="fw-bold">About Us</h1>
        <p class="text-muted fs-5">Serving delicious memories since 2023</p>
    </div>

    <!-- Intro Section -->
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <img src="/images/restaurant-about.jpg" class="img-fluid rounded shadow" alt="About our restaurant" />
        </div>
        <div class="col-md-6">
            <h3 class="fw-bold">Who We Are</h3>
            <p>
                At <strong>RestaurantPro</strong>, we're passionate about bringing you the best food experiences. Our chefs blend traditional recipes with modern twists to offer a diverse and flavorful menu. From spicy Indian dishes to cheesy Italian pizzas, there's something for everyone.
            </p>
            <p>
                We use only fresh, locally sourced ingredients and maintain the highest standards of hygiene and hospitality.
            </p>
        </div>
    </div>

    <!-- Vision & Mission -->
    <div class="row text-center mb-5">
        <div class="col-md-6">
            <div class="p-4 border rounded bg-light h-100">
                <h4 class="fw-bold text-warning">Our Vision</h4>
                <p>To be the most loved and trusted restaurant brand in the country by delivering consistent quality, taste, and experience.</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="p-4 border rounded bg-light h-100">
                <h4 class="fw-bold text-warning">Our Mission</h4>
                <p>To serve joy through food, create a warm atmosphere, and make every meal a delightful experience.</p>
            </div>
        </div>
    </div>

    <!-- Team Section -->
    <div class="text-center mb-5">
        <h3 class="fw-bold">Meet Our Team</h3>
        <p class="text-muted">Dedicated to excellence in every dish</p>
    </div>

    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <img src="/images/chef.jpg" class="rounded-circle shadow" width="150" height="150" alt="Chef" />
            <h5 class="mt-3 fw-bold">Chef Arjun Singh</h5>
            <p class="text-muted">Executive Chef</p>
        </div>
        <div class="col-md-4 mb-4">
            <img src="/images/manager.jpg" class="rounded-circle shadow" width="150" height="150" alt="Manager" />
            <h5 class="mt-3 fw-bold">Neha Patel</h5>
            <p class="text-muted">Operations Manager</p>
        </div>
        <div class="col-md-4 mb-4">
            <img src="/images/owner.jpg" class="rounded-circle shadow" width="150" height="150" alt="Owner" />
            <h5 class="mt-3 fw-bold">Sandeep Shah</h5>
            <p class="text-muted">Founder & Owner</p>
        </div>
    </div>
</div>
