@{
    Layout = "~/Views/Shared/_Layout_Index.cshtml";
}


<main>

<div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
            </div>

            <div class="carousel-inner">
                <div class="carousel-item active">
            <img src="/images/img1.png" class="d-block w-100" alt="Delicious Food" style="height: 550px; object-fit: cover;">
                    @* img-1 *@
<div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
    <h2 class="display-4 fw-bold">Welcome to RestaurantPro</h2>
    <p class="lead">Manage your restaurant with ease</p>
</div>
</div>
<div class="carousel-item">
            <img src="/images/img2.png" class="d-block w-100" alt="Restaurant Interior" style="height: 550px; object-fit: cover;">
    @* img-2 *@
    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
        <h2 class="display-4 fw-bold">Professional Management</h2>
        <p class="lead">Streamline your operations</p>
    </div>
</div>
        <div class="carousel-item">
            <img src="/images/img3.jpg" class="d-block w-100" alt="Chef Cooking" style="height: 550px; object-fit: cover;">
            <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                <h2 class="display-4 fw-bold">Quality Service</h2>
                <p class="lead">Excellence in every detail</p>
            </div>
        </div>
</div>

<button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
</button>
<button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
</button>
</div>




<section class="py-5 bg-light">
    <div class="container">
        <h3 class="text-center mb-5 display-5 fw-bold">Recently Most Ordered</h3>
        <div class="row g-4">

            <!-- Pizza 1 -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                        <img src="~/images/Margherita_Pizza.jpg" class="card-img-top" alt="Margherita">
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">Margherita Pizza</h5>
                        <p class="card-text text-muted">Classic pizza with tomatoes, mozzarella, and basil.</p>
                        <h6 class="text-success fw-bold mb-3">₹299</h6>
                        <form asp-action="AddToBasket" method="post">
                            <input type="hidden" name="MenuItemId" value="1" />
                            <input type="hidden" name="Quantity" value="1" />
                            <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Pizza 2 -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="~/images/Veggie_Pizza.jpg" class="card-img-top" alt="Pepperoni Pizza">
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">Pepperoni Pizza</h5>
                        <p class="card-text text-muted">Loaded with spicy pepperoni and cheese.</p>
                        <h6 class="text-success fw-bold mb-3">₹349</h6>
                        <form asp-action="AddToBasket" method="post">
                            <input type="hidden" name="MenuItemId" value="2" />
                            <input type="hidden" name="Quantity" value="1" />
                            <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Pizza 3 -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="~/images/Pepperoni_Pizza.jpg" class="card-img-top" alt="Veggie Pizza">
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">Veggie Pizza</h5>
                        <p class="card-text text-muted">Mushrooms, olives, onions & bell peppers.</p>
                        <h6 class="text-success fw-bold mb-3">₹279</h6>
                        <form asp-action="AddToBasket" method="post">
                            <input type="hidden" name="MenuItemId" value="3" />
                            <input type="hidden" name="Quantity" value="1" />
                            <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Pizza 4 -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="~/images/Paneer_Tikka_Pizza.jpg" class="card-img-top" alt="Paneer Tikka Pizza">
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">Paneer Tikka Pizza</h5>
                        <p class="card-text text-muted">Spicy Indian paneer on cheesy base.</p>
                        <h6 class="text-success fw-bold mb-3">₹329</h6>
                        <form asp-action="AddToBasket" method="post">
                            <input type="hidden" name="MenuItemId" value="4" />
                            <input type="hidden" name="Quantity" value="1" />
                            <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Pizza 5 -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="~/images/Cheese_Burst_Pizza.jpg" class="card-img-top" alt="Cheese Burst Pizza">
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">Cheese Burst Pizza</h5>
                        <p class="card-text text-muted">Oozing cheese filled in every bite.</p>
                        <h6 class="text-success fw-bold mb-3">₹389</h6>
                        <form asp-action="AddToBasket" method="post">
                            <input type="hidden" name="MenuItemId" value="5" />
                            <input type="hidden" name="Quantity" value="1" />
                            <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Pizza 6 -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="~/images/Cheeseburger.jpg" class="card-img-top" alt="BBQ Chicken Pizza">
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">Cheese burger</h5>
                        <p class="card-text text-muted">Grilled chicken with smoky BBQ sauce.</p>
                        <h6 class="text-success fw-bold mb-3">₹379</h6>
                        <form asp-action="AddToBasket" method="post">
                            <input type="hidden" name="MenuItemId" value="6" />
                            <input type="hidden" name="Quantity" value="1" />
                            <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Pizza 7 -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="~/images/Deluxe_Veggie_Pizza.jpg" class="card-img-top" alt="Farmhouse Pizza">
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">Farmhouse Pizza</h5>
                        <p class="card-text text-muted">Loaded with onion, capsicum, tomato & mushrooms.</p>
                        <h6 class="text-success fw-bold mb-3">₹309</h6>
                        <form asp-action="AddToBasket" method="post">
                            <input type="hidden" name="MenuItemId" value="7" />
                            <input type="hidden" name="Quantity" value="1" />
                            <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Pizza 8 -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="~/images/Deluxe_Veggie_Pizza.jpg" class="card-img-top" alt="Deluxe Veggie Pizza">
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">Deluxe Veggie Pizza</h5>
                        <p class="card-text text-muted">Black olives, corn, jalapenos & cheese.</p>
                        <h6 class="text-success fw-bold mb-3">₹339</h6>
                        <form asp-action="AddToBasket" method="post">
                            <input type="hidden" name="MenuItemId" value="8" />
                            <input type="hidden" name="Quantity" value="1" />
                            <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>







<!-- Feature Cards Section -->
<section class="py-5 bg-light">
    <div class="container">
        <h3 class="text-center mb-5 display-5 fw-bold">Restaurant Management Features</h3>
        <div class="row g-4">
            <!-- Menu Card -->
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcT02E9B3k0GjaEft9vCGqtamUXrMTFy1qYLXA&s" class="card-img-top" alt="Menu">
                    <div class="card-body text-center">
                        <i class="bi bi-menu-button-wide text-warning fs-1 mb-3"></i>
                        <h5 class="card-title fw-bold">Menu</h5>
                        <p class="card-text text-muted">Browse our delicious menu items</p>
                        <a href="#menu" class="btn btn-warning">View Menu</a>
                    </div>
                </div>
            </div>

            <!-- Categories Card -->
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <img src="data:image/jpeg;base64," class="card-img-top" alt="Categories">
                    <div class="card-body text-center">
                        <i class="bi bi-grid-3x3-gap text-success fs-1 mb-3"></i>
                        <h5 class="card-title fw-bold">Categories</h5>
                        <p class="card-text text-muted">Explore food categories</p>
                        <a href="#categories" class="btn btn-success">View Categories</a>
                    </div>
                </div>
            </div>

            <!-- Order Details Card -->
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcR3HPjqut8z5v6OKfY7M8ATcD20Ax5YBtxMSg&s" class="card-img-top" alt="Orders">
                    <div class="card-body text-center">
                        <i class="bi bi-cart-check text-danger fs-1 mb-3"></i>
                        <h5 class="card-title fw-bold">Order Details</h5>
                        <p class="card-text text-muted">Track your orders</p>
                        <a href="#orders" class="btn btn-danger">View Orders</a>
                    </div>
                </div>
            </div>

            <!-- Our Story Card -->
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <img src="data:image/jpeg;base64," class="card-img-top" alt="Our Story">
                    <div class="card-body text-center">
                        <i class="bi bi-book text-primary fs-1 mb-3"></i>
                        <h5 class="card-title fw-bold">Our Story</h5>
                        <p class="card-text text-muted">Learn about our restaurant</p>
                        <a href="#about" class="btn btn-primary">Read More</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
</main>