@model List<Reastaurant.Models.MenuItem>
@{
    ViewData["Title"] = "Menu";
}
@{
    Layout = "_Layout"; // ✅ Moved to the top

    ViewData["Title"] = "Dashboard";
}


<main>
    <section class="py-5 bg-light">
        <div class="container">
            <h3 class="text-center mb-5 display-5 fw-bold">Pizza</h3>
            <div class="row g-4">

                <!-- Pizza 1 -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="~/images/Margherita_Pizza.jpg" class="card-img-top" alt="Margherita">
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">Margherita Pizza</h5>
                            <p class="card-text text-muted">Classic pizza with tomatoes, mozzarella, and basil.</p>
                            <h6 class="text-success fw-bold mb-3">₹299</h6>
                            <form asp-action="AddToBasket" method="post">
                                <input type="hidden" name="MenuItemId" value="1" />
                                <input type="hidden" name="Quantity" value="1" />
                                <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Pizza 2 -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="~/images/Veggie_Pizza.jpg" class="card-img-top" alt="Pepperoni Pizza">
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">Pepperoni Pizza</h5>
                            <p class="card-text text-muted">Loaded with spicy pepperoni and cheese.</p>
                            <h6 class="text-success fw-bold mb-3">₹349</h6>
                            <form asp-action="AddToBasket" method="post">
                                <input type="hidden" name="MenuItemId" value="2" />
                                <input type="hidden" name="Quantity" value="1" />
                                <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Pizza 3 -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="~/images/Pepperoni_Pizza.jpg" class="card-img-top" alt="Veggie Pizza">
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">Veggie Pizza</h5>
                            <p class="card-text text-muted">Mushrooms, olives, onions & bell peppers.</p>
                            <h6 class="text-success fw-bold mb-3">₹279</h6>
                            <form asp-action="AddToBasket" method="post">
                                <input type="hidden" name="MenuItemId" value="3" />
                                <input type="hidden" name="Quantity" value="1" />
                                <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Pizza 4 -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="~/images/Paneer_Tikka_Pizza.jpg" class="card-img-top" alt="Paneer Tikka Pizza">
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">Paneer Tikka Pizza</h5>
                            <p class="card-text text-muted">Spicy Indian paneer on cheesy base.</p>
                            <h6 class="text-success fw-bold mb-3">₹329</h6>
                            <form asp-action="AddToBasket" method="post">
                                <input type="hidden" name="MenuItemId" value="4" />
                                <input type="hidden" name="Quantity" value="1" />
                                <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Pizza 5 -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="~/images/Cheese_Burst_Pizza.jpg" class="card-img-top" alt="Cheese Burst Pizza">
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">Cheese Burst Pizza</h5>
                            <p class="card-text text-muted">Oozing cheese filled in every bite.</p>
                            <h6 class="text-success fw-bold mb-3">₹389</h6>
                            <form asp-action="AddToBasket" method="post">
                                <input type="hidden" name="MenuItemId" value="5" />
                                <input type="hidden" name="Quantity" value="1" />
                                <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Pizza 6 -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="~/images/Cheeseburger.jpg" class="card-img-top" alt="BBQ Chicken Pizza">
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">Cheese burger</h5>
                            <p class="card-text text-muted">Grilled chicken with smoky BBQ sauce.</p>
                            <h6 class="text-success fw-bold mb-3">₹379</h6>
                            <form asp-action="AddToBasket" method="post">
                                <input type="hidden" name="MenuItemId" value="6" />
                                <input type="hidden" name="Quantity" value="1" />
                                <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Pizza 7 -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="~/images/Deluxe_Veggie_Pizza.jpg" class="card-img-top" alt="Farmhouse Pizza">
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">Farmhouse Pizza</h5>
                            <p class="card-text text-muted">Loaded with onion, capsicum, tomato & mushrooms.</p>
                            <h6 class="text-success fw-bold mb-3">₹309</h6>
                            <form asp-action="AddToBasket" method="post">
                                <input type="hidden" name="MenuItemId" value="7" />
                                <input type="hidden" name="Quantity" value="1" />
                                <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Pizza 8 -->
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="~/images/Deluxe_Veggie_Pizza.jpg" class="card-img-top" alt="Deluxe Veggie Pizza">
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">Deluxe Veggie Pizza</h5>
                            <p class="card-text text-muted">Black olives, corn, jalapenos & cheese.</p>
                            <h6 class="text-success fw-bold mb-3">₹339</h6>
                            <form asp-action="AddToBasket" method="post">
                                <input type="hidden" name="MenuItemId" value="8" />
                                <input type="hidden" name="Quantity" value="1" />
                                <button type="submit" class="btn btn-warning w-100">Add to Basket</button>
                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>
</main>